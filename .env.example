# User/Group IDs — match the user running Docker on the host
PUID=1000
PGID=1000

# Timezone
TZ=America/New_York

# qBittorrent credentials
QBT_USER=admin
QBT_PASS=changeme

# AirVPN forwarded port (used by qBittorrent and Gluetun firewall rules)
FIREWALL_VPN_INPUT_PORTS=12345

# Gluetun VPN provider settings (AirVPN example)
VPN_SERVICE_PROVIDER=airvpn
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=
SERVER_COUNTRIES=
